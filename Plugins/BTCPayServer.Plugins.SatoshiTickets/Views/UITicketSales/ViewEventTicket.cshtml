@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.SatoshiTickets.Data
@using BTCPayServer.Plugins.SatoshiTickets.ViewModels
@using BTCPayServer.Services
@inject DisplayFormatter DisplayFormatter
@model EventTicketViewModel
@{
    Layout = "_Layout";
    ViewData.SetLayoutModel(new LayoutModel(nameof(SatoshiTicketNavPages.SatoshiTicketIndex), $"{Model.EventTitle}") { ActiveCategory = nameof(SatoshiTicketNavPages) });
}


<div class="sticky-header d-flex flex-column align-items-start">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="List" asp-route-storeId="@Model.StoreId">Events</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center w-100">
        <h2>@ViewData["Title"]</h2>
        <div class="ms-auto">
            <a asp-action="ExportTickets" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" class="btn btn-success">Export Ticket Sales</a>
            <a asp-action="CheckInSettings" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" class="btn btn-success">Ticket Check-in</a>
        </div>
    </div>
</div>

<partial name="_StatusMessage" />

<div class="row g-3 mb-4 col-xxl-8">
    <div class="col-md-6">
        <div class="p-3 bg-light border rounded shadow-sm h-100">
            <h6 class="mb-1 text-muted">Total Tickets</h6>
            <h3 class="mb-0">@Model.TicketsCount</h3>
        </div>
    </div>
    <div class="col-md-6">
        <div class="p-3 bg-light border rounded shadow-sm h-100">
            <h6 class="mb-1 text-muted">Checked-in Tickets</h6>
            <h3 class="mb-0">@Model.CheckedInTicketsCount</h3>
        </div>
    </div>
</div>

<form class="d-flex flex-wrap flex-sm-nowrap align-items-center gap-3 mb-4 col-xxl-8" asp-action="ViewEventTicket"
      asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" method="get">
    <input asp-for="SearchText" class="form-control" name="searchText" placeholder="Search" />
</form>

@if (Model.TicketOrders.Any())
{
    <div class="table-responsive">
        <table id="invoices" class="table table-hover mass-action">
            <thead class="mass-action-head">
                <tr>
                    <th class="text-nowrap">Invoice</th>
                    <th class="text-nowrap">Quantity Purchased</th>
                    <th class="w-75px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.TicketOrders)
                {
                    <tr id="invoice_@ticket.InvoiceId">
                        <td class="text-break align-middle invoiceId-col">
                            <a asp-action="Invoice" asp-controller="UIInvoice" class="invoice-details-link" asp-route-invoiceId="@ticket.InvoiceId">@ticket.InvoiceId</a>
                        </td>
                        <td class="align-middle">@ticket.Quantity</td>
                        <td>
                            <button class="btn btn-link dropdown-toggle p-0" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#collapse_@ticket.OrderId" aria-expanded="false" aria-controls="collapse_@ticket.OrderId">
                               Show Ticket
                            </button>
                        </td>
                    </tr>
                    <tr class="collapse" id="collapse_@ticket.OrderId">
                        <td colspan="7" class="p-0">
                            <div class="card card-body border-0">
                                <div class="table-responsive">
                                    <table class="table table-borderless mb-0">
                                        <thead>
                                            <tr>
                                                <th>Ticket Number</th>
                                                <th>Ticket Tier</th>
                                                <th>First Name</th>
                                                <th>Last Name</th>
                                                <th>Email</th>
                                                <th>Amount</th>
                                                <th>Currency</th>
                                                <th>Checkin Attendee</th>
                                                <th>Send Reminder</th>
                                                <th class="text-end">Delete Ticket</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ticketVm in ticket.Tickets)
                                            {
                                                <tr>
                                                    <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis;">@ticketVm.TicketNumber</td>
                                                    <td>@ticketVm.TicketTypeName</td>
                                                    <td>@ticketVm.FirstName</td>
                                                    <td>@ticketVm.LastName</td>
                                                    <td>@ticketVm.Email</td>
                                                    <td>@ticketVm.Amount</td>
                                                    <td>@ticketVm.Currency</td>
                                                    <td>
                                                        @if (!ticketVm.CheckedIn)
                                                        {
                                                            <a asp-action="CheckinTicketAttendee" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" asp-route-ticketNumber="@ticketVm.TicketNumber">Check In</a>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (!ticketVm.CheckedIn)
                                                        {
                                                            <a asp-action="SendTicketReminder" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" asp-route-ticketId="@ticketVm.Id" asp-route-orderId="@ticket.OrderId">Resend Ticket Email</a>
                                                        }
                                                    </td>
                                                    <td class="text-end">
                                                        <a asp-action="DeleteTicket" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" asp-route-ticketId="@ticketVm.Id" class="text-danger ms-2">Delete</a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-secondary mt-3">
        No tickets found for this event.
    </p>
}

@section PageFootContent {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.querySelector('input[name="searchText"]');
            searchInput.addEventListener("input", function () {
                if (this.value.trim() === "") {
                    window.location.href = window.location.pathname;
                }
            });
        });
    </script>

}

