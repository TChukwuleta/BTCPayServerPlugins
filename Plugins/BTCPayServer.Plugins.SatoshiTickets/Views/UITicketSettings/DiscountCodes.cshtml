@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.SatoshiTickets.Data
@using BTCPayServer.Plugins.SatoshiTickets.ViewModels
@model DiscountCodeListViewModel
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(SatoshiTicketNavPages.SatoshiTicketIndex), "Discount Codes") { ActiveCategory = nameof(SatoshiTicketNavPages) });
}

<div class="sticky-header">
    <h2>
        Discount Codes
        <span class="text-muted h5 ms-2">@Model.EventTitle</span>
    </h2>
    <a asp-controller="UITicketSettings" asp-action="CreateDiscountCode" asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId"
       class="btn btn-primary" role="button">Create Discount Code</a>
</div>

<partial name="_StatusMessage" />

@if (Model.Codes != null && Model.Codes.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Discount</th>
                    <th>Applies To</th>
                    <th>Uses</th>
                    <th>Expiry</th>
                    <th>Status</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var code in Model.Codes)
                {
                    <tr>
                        <td class="fw-bold">@code.Code</td>
                        <td>
                            @if (code.DiscountType == DiscountType.Percentage)
                            {
                                <span>@code.Value.ToString("0.##")%</span>
                            }
                            else
                            {
                                <span>@code.Value.ToString("N2") @Model.Currency</span>
                            }
                        </td>
                        <td>@(string.IsNullOrEmpty(code.TicketTypeName) ? "All ticket types" : code.TicketTypeName)</td>
                        <td>@code.UsesCount@(code.MaxUses.HasValue ? $" / {code.MaxUses.Value}" : "")</td>
                        <td>@(code.ExpiryDate.HasValue ? code.ExpiryDate.Value.ToString("MMM d, yyyy") : "—")</td>
                        <td>
                            @if (code.DiscountCodeState == DiscountCodeState.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex align-items-center gap-3">
                                <a asp-controller="UITicketSettings" asp-action="EditDiscountCode"
                                   asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" asp-route-discountCodeId="@code.Id">Edit</a>
                                <a asp-controller="UITicketSettings" asp-action="ToggleDiscountCode"
                                   asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" asp-route-discountCodeId="@code.Id">
                                    @(code.DiscountCodeState == DiscountCodeState.Active ? "Disable" : "Activate")
                                </a>
                                @if (code.UsesCount == 0)
                                {
                                    <a asp-controller="UITicketSettings" asp-action="DeleteDiscountCode"
                                       asp-route-storeId="@Model.StoreId" asp-route-eventId="@Model.EventId" asp-route-discountCodeId="@code.Id"
                                       class="text-danger"
                                       onclick="return confirm('Delete discount code @code.Code?');">Delete</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-secondary mt-4">No discount codes yet. Create one to offer early-bird, speaker, or volunteer pricing.</p>
}
