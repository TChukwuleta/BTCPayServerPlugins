@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.PhoenixdManager.ViewModels
@model DashboardViewModel
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(PhoenixdViewAction.Summary), "Phoenixd Manager") { ActiveCategory = nameof(PhoenixdViewAction) });
    string Sat(long v) => v.ToString("N0");
    string TsMs(long? unixMs) => unixMs is null or 0 ? "-" : DateTimeOffset.FromUnixTimeMilliseconds(unixMs.Value).UtcDateTime.ToString("yyyy-MM-dd HH:mm");
}

<div class="sticky-header d-flex align-items-center justify-content-between">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    <a asp-action="Settings" class="btn btn-secondary">Settings</a>
</div>

<partial name="_StatusMessage" />

@if (!Model.Configured)
{
    <div class="alert alert-warning">
        Phoenixd is not configured yet. <a asp-action="Settings" class="alert-link">Add your server URL and password</a> to begin.
    </div>
    return;
}

<div class="row row-cols-2 row-cols-lg-4 g-3 mb-4">
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="text-muted">Balance</h6>
                <div class="h4 mb-0">@Sat(Model.Balance?.BalanceSat ?? 0) <small class="text-muted">sat</small></div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="text-muted">Fee credit</h6>
                <div class="h4 mb-0">@Sat(Model.Balance?.FeeCreditSat ?? 0) <small class="text-muted">sat</small></div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="text-muted">Channels</h6>
                <div class="h4 mb-0">@Model.Channels.Count</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="text-muted">Block height</h6>
                <div class="h4 mb-0">@(Model.NodeInfo?.BlockHeight.ToString("N0") ?? "-")</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Node</h5>
        <dl class="row mb-0">
            <dt class="col-sm-3">Node ID</dt>
            <dd class="col-sm-9"><code class="text-break user-select-all fs-6 text-body">@Model.NodeInfo?.NodeId</code></dd>
            <dt class="col-sm-3">Chain</dt>
            <dd class="col-sm-9 fw-semibold">@Model.NodeInfo?.Chain</dd>
            <dt class="col-sm-3">Version</dt>
            <dd class="col-sm-9 fw-semibold">@Model.NodeInfo?.Version</dd>
            <dt class="col-sm-3">Lightning Address</dt>
            <dd class="col-sm-9">
                @if (Model.LnAddress is not null)
                {
                    <code class="text-break user-select-all fs-6 text-body">@Model.LnAddress</code>
                }
                else
                {
                    <span class="text-muted">unavailable</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="row g-5">
    <div class="col-lg-6">
        <h5>Recent incoming</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Created</th>
                        <th>Desc</th>
                        <th>Received</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.RecentIncoming)
                    {
                        <tr>
                            <td class="text-nowrap">@TsMs(p.CreatedAt)</td>
                            <td>@p.Description</td>
                            <td>@Sat(p.ReceivedSat)</td>
                            <td class="text-end">@(p.IsPaid ? "paid" : p.IsExpired ? "expired" : "pending")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-6">
        <h5>Recent outgoing</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Created</th
                        ><th>Sent (sats)</th>
                        <th class="text-end">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.RecentOutgoing)
                    {
                        <tr>
                            <td class="text-nowrap">@TsMs(p.CreatedAt)</td>
                            <td>@Sat(p.Sent)</td>
                            <td class="text-end">@(p.IsPaid ? "paid" : "pending")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>