@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.PhoenixdManager.ViewModels

@model ReceiveViewModel
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(PhoenixdViewAction.Receive), "Receive Payment") { ActiveCategory = nameof(PhoenixdViewAction) });
    string Sat(long v) => v.ToString("N0");
}

<div class="sticky-header d-flex align-items-center justify-content-between">
    <h2 class="mb-0">Receive</h2>
</div>

<partial name="_StatusMessage" />

@if (!Model.Configured)
{
    <div class="alert alert-warning">
        Phoenixd is not configured yet. <a asp-action="Settings" class="alert-link">Add your server URL and password</a> to begin.
    </div>
    return;
}

@if (Model.Error is not null)
{
    <div class="mb-4" style="max-width: 640px;">
        <span class="badge rounded-pill bg-danger-subtle text-danger-emphasis px-3 py-2">Error</span>
        <div class="text-danger small mt-2">@Model.Error</div>
    </div>
}

@if (Model.HasResult)
{
    <div style="max-width: 420px;">
        @if (Model.AmountSat is > 0)
        {
            <p class="text-muted mb-3">@Sat(Model.AmountSat.Value) sat &middot; @Model.Description</p>
        }

        <div class="input-group">
            <input class="form-control" id="inv-value" value="@Model.Invoice" readonly />
            <button class="btn btn-outline-secondary" type="button" id="copy-btn">Copy</button>
        </div>

        <a asp-action="Receive" class="btn btn-link px-0 mt-3">Create another</a>
    </div>
}
else
{
    <form method="post" asp-action="Receive" style="max-width: 640px;">
        <div class="mb-3">
            <label class="form-label">Amount (sat)</label>
            <input name="amountSat" type="number" class="form-control" value="@Model.AmountSat" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <input name="description" class="form-control" value="@Model.Description" required />
        </div>
        <button class="btn btn-primary">Create invoice</button>
    </form>
}

@section PageFootContent {
    <script>
        (function () {
            var btn = document.getElementById('copy-btn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var val = document.getElementById('inv-value').value;
                var done = () => { btn.textContent = 'Copied'; setTimeout(() => btn.textContent = 'Copy', 1500); };
                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(val).then(done);
                } else {
                    var el = document.getElementById('inv-value');
                    el.select(); el.setSelectionRange(0, 99999);
                    document.execCommand('copy'); done();
                }
            });
        })();
    </script>
}