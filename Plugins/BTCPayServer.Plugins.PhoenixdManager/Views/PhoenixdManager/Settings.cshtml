@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.PhoenixdManager.ViewModels
@model PhoenixdSettings
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(PhoenixdViewAction.Summary), "Phoenixd Settings") { ActiveCategory = nameof(PhoenixdViewAction) });
}

<div class="sticky-header">
    <h2>@ViewData["Title"]</h2>
</div>

<partial name="_StatusMessage" />

<div class="row">
    <div class="col-xxl-8">
        <form method="post" asp-controller="PhoenixdManager" asp-action="Settings">
            <div class="form-group">
                <label asp-for="ServerUrl" class="form-label">phoenixd Server URL</label>
                <input asp-for="ServerUrl" class="form-control" placeholder="http://phoenixd:9740" />
                <span asp-validation-for="ServerUrl" class="text-danger"></span>
                <div class="form-text">
                    The base URL of the phoenixd HTTP API. Inside Docker this is usually the
                    container name and port, e.g. <code>http://phoenixd:9740</code>.
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">HTTP Password (full access)</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-text">
                    The <code>http-password</code> from <code>phoenix.conf</code>. Required for
                    send/pay actions. Auth uses an empty username with this value.
                </div>
            </div>

            <div class="form-group">
                <label asp-for="LimitedAccessPassword" class="form-label">HTTP Password (limited access, optional)</label>
                <input asp-for="LimitedAccessPassword" type="password" class="form-control" />
                <div class="form-text">
                    Optional <code>http-password-limited-access</code>. When set, read-only calls
                    (info, balance, channels, history) use it instead of the full-access password.
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" name="command" value="save" class="btn btn-primary">Save</button>
                <button type="submit" name="command" value="test" class="btn btn-secondary">Test connection</button>
                <a asp-action="Index" class="btn btn-link">Back</a>
            </div>
        </form>
    </div>
</div>
