@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.PhoenixdManager.ViewModels
@model DashboardViewModel
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(PhoenixdViewAction.Actions), "Phoenixd Tools") { ActiveCategory = nameof(PhoenixdViewAction) });
}

<div class="sticky-header d-flex align-items-center justify-content-between">
    <h2 class="mb-0">Tools</h2>
</div>

<partial name="_StatusMessage" />

@if (!Model.Configured)
{
    <div class="alert alert-warning">
        Phoenixd is not configured yet. <a asp-action="Settings" class="alert-link">Add your server URL and password</a> to begin.
    </div>
    return;
}

<div style="max-width: 640px;">
    <h5 class="mb-3">Decode invoice or offer</h5>
    <form method="post" asp-action="Decode" class="mb-5">
        <div class="mb-3">
            <label class="form-label">Invoice or offer</label>
            <input name="value" class="form-control" placeholder="lnbc... or lno..." required />
        </div>
        <button class="btn btn-secondary">Decode</button>
    </form>

    <h5 class="mb-3">Estimate liquidity fees</h5>
    <form method="post" asp-action="EstimateLiquidity">
        <div class="mb-3">
            <label class="form-label">Amount (sat)</label>
            <input name="amountSat" type="number" class="form-control" required />
        </div>
        <button class="btn btn-secondary">Estimate</button>
    </form>

</div>