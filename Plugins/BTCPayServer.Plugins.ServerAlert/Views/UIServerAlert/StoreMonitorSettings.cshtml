@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.ServerAlert.Data
@using BTCPayServer.Plugins.ServerAlert.ViewModels
@using BTCPayServer.Plugins.ServerAlert
@model StoreMonitorViewModel
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(ServerAlertPlugin), "Store Health Monitor"));
}

<div class="sticky-header">
    <h2>Store Health Monitor — @Model.StoreName</h2>
</div>
<partial name="_StatusMessage" />

<form method="post" asp-action="StoreMonitorSettings" asp-route-storeId="@Model.StoreId">
    <div class="row">
        <div class="col-xl-8 col-xxl-constrain">

            <div class="form-group mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <label class="form-label mb-0 fw-semibold">Enable Store Health Monitor</label>
                    <div class="form-check form-switch mb-0">
                        <input asp-for="Enabled" class="form-check-input" type="checkbox" role="switch" />
                    </div>
                </div>
                <small class="text-secondary">Monitor this store for issues and receive alerts when action is needed.</small>
            </div>

            <div id="store-monitor-settings" class="@(Model.Enabled ? "" : "d-none")">

                <div class="form-group mb-4">
                    <label class="form-label fw-semibold">Payouts</label>
                    <div class="form-check mb-2">
                        <input asp-for="AlertOnUnprocessedPayout" class="form-check-input" type="checkbox" />
                        <label asp-for="AlertOnUnprocessedPayout" class="form-check-label">
                            Alert when approved payouts are not processed
                        </label>
                    </div>
                    <div class="d-flex align-items-center gap-2 ms-4">
                        <label class="form-label mb-0 text-secondary small">After</label>
                        <input asp-for="UnprocessedPayoutThresholdHours" class="form-control form-control-sm" type="number" min="1" max="168" style="max-width:80px;" />
                        <span class="text-secondary small">hours</span>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label fw-semibold">Lightning</label>
                    <div class="d-flex flex-column gap-2">
                        <div class="form-check">
                            <input asp-for="AlertOnLightningNodeOffline" class="form-check-input" type="checkbox" />
                            <label asp-for="AlertOnLightningNodeOffline" class="form-check-label">
                                Alert when Lightning node is offline or unreachable
                            </label>
                        </div>
                        <div class="form-check">
                            <input asp-for="AlertOnLowLightningInbound" class="form-check-input" type="checkbox" />
                            <label asp-for="AlertOnLowLightningInbound" class="form-check-label">
                                Alert when inbound capacity is low
                            </label>
                        </div>
                        <div class="d-flex align-items-center gap-2 ms-4">
                            <label class="form-label mb-0 text-secondary small">Threshold</label>
                            <input asp-for="LowLightningInboundThresholdPercent" class="form-control form-control-sm" type="number" min="1" max="100" style="max-width:80px;" />
                            <span class="text-secondary small">% remaining</span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Delivery" class="form-label fw-semibold">Alert Delivery</label>
                    <select asp-for="Delivery" class="form-select" style="max-width:280px;">
                        <option value="@AlertDelivery.BellOnly">Bell notification only</option>
                        <option value="@AlertDelivery.EmailOnly">Email only</option>
                        <option value="@AlertDelivery.BothBellAndEmail">Bell and email</option>
                    </select>
                </div>

            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </div>
</form>

@section PageFootContent {
    <script>
        document.getElementById('Enabled').addEventListener('change', function () {
            document.getElementById('store-monitor-settings').classList.toggle('d-none', !this.checked);
        });
    </script>
}