@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.Plugins.ServerAlert.Data
@using BTCPayServer.Plugins.ServerAlert.ViewModels
@model ServerMonitorViewModel
@{
    ViewData.SetLayoutModel(new LayoutModel(nameof(ServerAlertNavPages.ServerAlertMonitor), "Server Monitor") { ActiveCategory = nameof(ServerAlertNavPages) });
}

<form method="post" asp-action="ServerMonitorSettings">
    <div class="sticky-header">
        <h2>Health Monitor</h2>
        <div class="d-flex gap-3 mt-3 mt-sm-0">
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </div>
    <partial name="_StatusMessage" />

    <div class="row">
        <div class="col-xl-8 col-xxl-constrain">
            <div class="form-group">
                <div class="d-flex align-items-center">
                    <input asp-for="Enabled" type="checkbox" class="btcpay-toggle me-3" id="Enabled" />
                    <label for="Enabled" class="form-check-label">
                        <span class="fw-semibold">Enable Server Health Monitor</span>
                    </label>
                </div>
            </div>

            <div id="monitor-settings" class="@(Model.Enabled ? "" : "d-none")">

                <div class="form-group">
                    <label class="form-label fw-semibold">Checks to Run</label>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-start">
                            <input asp-for="MonitorBitcoinNode" type="checkbox" class="btcpay-toggle me-3" id="MonitorBitcoinNode" />
                            <label for="MonitorBitcoinNode" class="form-check-label">
                                <span class="fw-semibold">Bitcoin Node</span>
                                <div class="text-secondary">Alerts if the node goes offline</div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Delivery" class="form-label fw-semibold">Alert Delivery</label>
                    <select asp-for="Delivery" class="form-select w-auto">
                        <option value="@AlertDelivery.BellOnly">Bell notification only</option>
                        <option value="@AlertDelivery.EmailOnly">Email only</option>
                        <option value="@AlertDelivery.BothBellAndEmail">Bell and email</option>
                    </select>
                </div>

            </div>
        </div>
    </div>
</form>

@if (Model.RecentAlerts.Any())
{
    <div class="row mt-4">
        <div class="col-xl-10">
            <h5 class="fw-semibold mb-3">Recent Check Log</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Check</th>
                            <th>Status</th>
                            <th>Message</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.RecentAlerts)
                        {
                            var (badge, label) = log.Status switch
                            {
                                MonitorStatus.Critical => ("danger", "Critical"),
                                MonitorStatus.Warning => ("warning", "Warning"),
                                _ => ("success", "Healthy")
                            };
                            <tr>
                                <td class="fw-semibold">@log.CheckName</td>
                                <td><span class="badge bg-@badge">@label</span></td>
                                <td class="text-secondary small">@log.Message</td>
                                <td class="small text-secondary text-nowrap">@log.FiredAt.ToString("MMM dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section PageFootContent {
    <script>
        document.getElementById('Enabled').addEventListener('change', function () {
            document.getElementById('monitor-settings').classList.toggle('d-none', !this.checked);
        });
    </script>
}